				{
					"type": "script",
					"language": "javascript",
					"script": [
						"// time setting",
						"globalThis.stageDuration = 62.5; // seconds that the level takes ",
						"globalThis.stageStartTime = runtime.gameTime;",
						"",
						"",
						"// progress bar",
						"const fill = runtime.objects.Progress_bar_fill.getFirstInstance();",
						"if (fill) {",
						"    globalThis.maxBarWidth = fill.width;",
						"    fill.width = 0; // start with zero fill",
						"}",
						"",
						"// score",
						"runtime.globalVars.Score = 0;",
						"",
						"// global vars for fade after the level",
						"globalThis.finished = false;",
						"globalThis.fade = 100;   // opacity",
						"globalThis.fadeSpeed = 120;  // opacity / second",
						""
					]
				}
