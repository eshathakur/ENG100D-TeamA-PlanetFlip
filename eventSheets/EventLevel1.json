		{
			"eventType": "block",
			"conditions": [
				{
					"id": "every-x-seconds",
					"objectClass": "System",
					"sid": 161626434553208,
					"parameters": {
						"interval-seconds": "2.8"
					}
				}
			],
			"actions": [
				{
					"type": "script",
					"language": "javascript",
					"script": [
						"const SPEED = 100;\t//speed of moving obstacles",
						"const MARGIN = 80;\t//margin for the positions",
						"",
						"const player = runtime.objects.Player_sprite.getFirstInstance();",
						"if (!player) return;",
						"",
						"const H = runtime.layout.height / 2;\t//height of the screen",
						"const x = player.x + 500;\t\t\t \t//starting x coordinates for corals",
						"",
						"const TOP_Y = 0 + MARGIN;\t//y coordinate for the top coral",
						"const BOT_Y = H - MARGIN;\t//y coordinate for the bottom coral",
						"",
						"const minScaleY = 1.0;\t\t//lower bound for scale",
						"const maxScaleY = 2.5;\t\t//upper bound for scale",
						"",
						"const sTop = minScaleY + Math.random() * (maxScaleY - minScaleY);\t\t\t//scale for the top coral",
						"const sBot = minScaleY + Math.random() * (maxScaleY - minScaleY);\t\t\t//scale for the bottom coral",
						"",
						"//creating the top coral",
						"const top = runtime.objects.Coral.createInstance(0, x, TOP_Y);",
						"if (top) {",
						"  top.animationSpeed = 0;",
						"  top.animationFrame = Math.floor(Math.random() * 4);\t//setting to random frame of the coral sprite",
						"",
						"  top.height = -top.height * sTop;\t//randomising the scale and flip vertically",
						"",
						"  const b = top.behaviors.Bullet;\t//making it a bullet makes it move by itself",
						"  b.speed = SPEED;\t\t\t\t\t//setting the speed",
						"}",
						"",
						"//creating the bottom coral",
						"const bot = runtime.objects.Coral.createInstance(0, x, BOT_Y);",
						"if (bot) {",
						"  bot.animationSpeed = 0;",
						"  bot.animationFrame = Math.floor(Math.random() * 4);",
						"  ",
						"  bot.height = bot.height * sBot;",
						"",
						"  const b = bot.behaviors.Bullet;",
						"  b.speed = SPEED;",
						"}"
					]
				}
			],
			"sid": 893238584961485
		},
