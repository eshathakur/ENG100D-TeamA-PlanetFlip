					"parameters": {
						"speed": "2"
					}
				},
				{
					"type": "script",
					"language": "javascript",
					"script": [
						"// time setting",
						"globalThis.stageDuration = 19.16; // level takes 19.16 seconds",
						"globalThis.stageStartTime = runtime.gameTime;",
						"",
						"// progress bar",
						"const fill = runtime.objects.Progress_bar_fill.getFirstInstance();",
						"if (fill) {",
						"    globalThis.maxBarWidth = fill.width;",
						"    fill.width = 0; // start with zero fill",
						"}",
						"",
						"// score",
						"runtime.globalVars.Score = 0;"
					]
				}
			],
			"sid": 884896111873384
		},
		{
			"eventType": "block",
			"conditions": [
				{
					"id": "every-tick",
					"objectClass": "System",
					"sid": 110712669300771
				}
			],
			"actions": [
				{
					"type": "script",
					"language": "javascript",
					"script": [
						"const scrollSpeed = 100",
						"const bg = runtime.objects.Background.getFirstInstance();",
						"// the background keeps moving to the left until it reaches the end",
						"if (bg && bg.x > -715) {",
						"\tbg.x -= scrollSpeed * runtime.dt;",
						"} else {",
						"\truntime.timeScale = 0;",
						"}",
						"",
						"",
						"// filling the progress bar",
						"const fill = runtime.objects.Progress_bar_fill.getFirstInstance();",
						"if (!fill) return;",
						"",
						"// elapsed time",
						"const elapsed = runtime.gameTime - globalThis.stageStartTime;",
						"",
						"// progress (0~1)",
						"let progress = elapsed / globalThis.stageDuration;",
						"progress = Math.max(0, Math.min(progress, 1));",
						"",
						"// Adjusting the width",
						"fill.width = progress * globalThis.maxBarWidth;",
						"",
						"// when the stage is done",
						"if (progress >= 1) {",
						"    console.log(\"Stage Complete!\");",
						"}",
						"",
						"// updating the score text",
						"const t = runtime.objects.ScoreText.getFirstInstance();",
						"if (t) t.text = \"Score: \" + runtime.globalVars.Score;"
					]
				}
			],
			"sid": 563844446089038
		},
