		{
			"eventType": "block",
			"conditions": [
				{
					"id": "every-tick",
					"objectClass": "System",
					"sid": 110712669300771
				}
			],
			"actions": [
				{
					"type": "script",
					"language": "javascript",
					"script": [
						"const scrollSpeed = 40",
						"const bg = runtime.objects.Background.getFirstInstance();",
						"// the background keeps moving to the left until it reaches the end",
						"if (bg && bg.x > -450) {",
						"\tbg.x -= scrollSpeed * runtime.dt;",
						"} else {",
						"\t",
						"}",
						"",
						"",
						"// filling the progress bar",
						"const fill = runtime.objects.Progress_bar_fill.getFirstInstance();",
						"if (!fill) return;",
						"",
						"// elapsed time",
						"const elapsed = runtime.gameTime - globalThis.stageStartTime;",
						"",
						"// progress (0~1)",
						"let progress = elapsed / globalThis.stageDuration;",
						"progress = Math.max(0, Math.min(progress, 1));",
						"",
						"// Adjusting the width",
						"fill.width = progress * globalThis.maxBarWidth;",
						"",
						"// when the stage is done",
						"if (progress >= 1) {",
						"    //console.log(\"Stage Complete!\");",
						"\tif(!globalThis.finished){",
						"\t\tglobalThis.finished = true;",
						"\t}",
						"}",
						"",
						"// updating the score text",
						"const t = runtime.objects.ScoreText.getFirstInstance();",
						"if (t) t.text = \"Score: \" + runtime.globalVars.Score;",
						"",
						"const player = runtime.objects.Player_sprite.getFirstInstance();",
						"if(player && player.y < 0){",
						"\tconst phys = player.behaviors.Physics;",
						"\tphys.setVelocity(phys.getVelocityX(), 600);",
						"}",
						"if(player && player.y > 800){",
						"\tconst phys = player.behaviors.Physics;",
						"\tphys.setVelocity(phys.getVelocityX(), -600);",
						"}",
						"",
						"// fade after the level",
						"const dt = runtime.dt;",
						"const fadeObj = runtime.objects.Fade.getFirstInstance();",
						"if (!fadeObj) return;",
						"",
						"if (!globalThis.finished && globalThis.fade > 0) {",
						"    globalThis.fade -= globalThis.fadeSpeed * dt;",
						"}",
						"",
						"if (globalThis.finished && globalThis.fade < 100) {",
						"    globalThis.fade += globalThis.fadeSpeed * dt;",
						"}",
						"",
						"// clamp",
						"globalThis.fade = Math.max(0, Math.min(100, globalThis.fade));",
						"",
						"// apply opacity",
						"fadeObj.opacity = globalThis.fade / 100;",
						"",
						"",
						"// stop all sprites when finished",
						"if (globalThis.finished) {",
						"\tfor (let fish of runtime.objects.Fish.getAllInstances()) {",
						"\t\tfish.behaviors.Bullet.speed = 0;",
						"\t}",
						"\tfor (let coral of runtime.objects.Coral.getAllInstances()) {",
						"\t\tcoral.behaviors.Bullet.speed = 0;",
						"\t}",
						"\tfor (let trash of runtime.objects.Trash.getAllInstances()) {",
						"\t\ttrash.behaviors.Bullet.speed = 0;",
						"\t}",
						"\tlet player = runtime.objects.Player_sprite.getFirstInstance();",
						"\tif(!player) return;",
						"",
						"\tplayer.behaviors.Physics.setVelocity(0, 0);",
						"\tplayer.behaviors.Physics.angularVelocity = 0;",
						"\tplayer.behaviors.Physics.enabled = false;",
						"}"
					]
				}
			],
			"sid": 563844446089038
		},
