		{
			"eventType": "block",
			"conditions": [
				{
					"id": "every-x-seconds",
					"objectClass": "System",
					"sid": 105063324635504,
					"parameters": {
						"interval-seconds": "random(1.5, 4.0)"
					}
				}
			],
			"actions": [
				{
					"type": "script",
					"language": "javascript",
					"script": [
						"const SPEED = 100;\t\t// speed of corals",
						"const MARGIN_MIN = 100;\t// lower bound for y coordinate margin",
						"const MARGIN_MAX = 180;\t// upper bound for y coordinate margin",
						"",
						"const player = runtime.objects.Player_sprite.getFirstInstance();",
						"if (!player) return;",
						"",
						"const H = runtime.layout.height;\t// height of the screen",
						"const x = player.x + 1800;\t\t\t \t// starting x coordinates for corals",
						"",
						"const BOT_Y = H - (MARGIN_MIN + Math.random() * (MARGIN_MAX - MARGIN_MIN));\t// randomizing y coordinate for corals",
						"",
						"const minScale = 0.9;\t\t// lower bound for scale",
						"const maxScale = 1.2;\t\t// upper bound for scale",
						"",
						"const scale = minScale + Math.random() * (maxScale - minScale);\t\t\t\t//randomizing coral scales",
						"",
						"const NUM_ANIM = 36;\t\t// number of coral animations",
						"",
						"// creating the coral",
						"let coral = runtime.objects.Coral.createInstance(0, x, BOT_Y);",
						"if (coral) {",
						"",
						"  const animIndex = Math.floor(Math.random() * NUM_ANIM) + 1;",
						"  coral.setAnimation(\"coral\" + animIndex);",
						"  ",
						"  coral.animationSpeed = 0;",
						"  coral.animationFrame = Math.floor(Math.random() * 2);",
						"  ",
						"  coral.height = coral.height * scale;",
						"  coral.width = coral.width * scale;",
						"",
						"  const b = coral.behaviors.Bullet;",
						"  b.speed = SPEED;",
						"}"
					]
				}
			],
			"sid": 893238584961485
		},
